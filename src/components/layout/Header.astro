---
import { Phone, ChevronDown, LayoutGrid, ArrowRight } from 'lucide-astro';
import { normalizeRoute, stripBase, withBase } from '../../utils/paths';

const solucionesItems = [
  { id: 'outsourcing-contable', titulo: 'Outsourcing Contable' },
  { id: 'asesoria-tributaria', titulo: 'Asesoría Tributaria y Planeación Fiscal' },
  { id: 'gestion-nomina', titulo: 'Gestión de Nómina y Prestaciones' },
  { id: 'facturacion-electronica', titulo: 'Facturación Electrónica DIAN' },
  { id: 'estados-financieros', titulo: 'Estados Financieros e Interpretación' },
  { id: 'niif-pymes', titulo: 'NIIF para PyMEs 2027' },
  { id: 'revisoria-fiscal', titulo: 'Revisoría Fiscal' },
  { id: 'analisis-financiero', titulo: 'Análisis Financiero Estratégico' },
  { id: 'constitucion-empresa', titulo: 'Constitución de Empresa' },
  { id: 'optimizacion-procesos', titulo: 'Optimización y Modernización de Procesos' },
  { id: 'auditoria-aseguramiento', titulo: 'Auditoría y Aseguramiento' },
];

const navLinks = [
  { href: withBase('metodologia/'), route: '/metodologia', label: 'Metodología' },
  { href: withBase('recursos/'), route: '/recursos', label: 'Recursos' },
];

const currentPath = normalizeRoute(stripBase(Astro.url.pathname));
const isSolucionesSection = currentPath.startsWith('/servicios') || currentPath === '/soluciones';
const homeHref = withBase();
const contactoHref = withBase('contacto/');
const solucionesHref = withBase('soluciones/');
---
<header
  class="sticky top-0 z-50
         bg-white/95 backdrop-blur-md
         border-b border-gray-100"
>
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={homeHref} class="flex items-center no-underline hover:opacity-90 transition-opacity duration-300">
      <img
        src={withBase('logo.webp')}
        alt="TAC ADVISORS"
        class="h-[50px] w-auto"
        width="138"
        height="50"
        fetchpriority="high"
      />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <!-- Soluciones dropdown -->
      <div
        class="relative group/nav"
        id="soluciones-dropdown-trigger"
      >
        <button
          type="button"
          class:list={[
            'flex items-center gap-1 text-sm font-medium transition-colors duration-300 relative py-2',
            isSolucionesSection ? 'text-primary' : 'text-gray-700 hover:text-primary'
          ]}
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="soluciones-dropdown"
          id="soluciones-dropdown-btn"
        >
          Soluciones
          <ChevronDown size={14} stroke-width={2} class="transition-transform duration-200 group-hover/nav:rotate-180 group-data-[open]/nav:rotate-180" />
          <span
            class:list={[
              'absolute -bottom-1 left-0 right-0 h-0.5 bg-primary transition-transform duration-300 origin-left',
              isSolucionesSection ? 'scale-x-100' : 'scale-x-0 group-hover/nav:scale-x-100'
            ]}
          />
        </button>
        <div
          id="soluciones-dropdown"
          class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover/nav:opacity-100 group-hover/nav:visible transition-all duration-200 ease-out z-50"
          role="menu"
          aria-label="Menú de soluciones"
        >
          <div class="w-[32rem] bg-white rounded-xl shadow-lg border border-gray-100 py-2 overflow-hidden">
            <a
              href={solucionesHref}
              class="flex items-center gap-3 px-5 py-3 text-gray-700 hover:bg-primary/5 hover:text-primary transition-colors duration-200 no-underline group/link"
              role="menuitem"
            >
              <span class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <LayoutGrid size={18} stroke-width={2} class="text-primary" />
              </span>
              <span class="font-semibold">Ver todas las soluciones</span>
              <ArrowRight size={14} class="ml-auto text-gray-400 group-hover/link:text-primary group-hover/link:translate-x-0.5 transition-all" />
            </a>
            <div class="border-t border-gray-100 my-2" />
            <div class="grid grid-cols-2 gap-x-4 gap-y-0.5 px-3 py-1 max-h-[70vh] overflow-y-auto">
              {solucionesItems.map((item) => (
                <a
                  href={withBase(`servicios/${item.id}/`)}
                  class="block px-3 py-2.5 text-sm text-gray-600 hover:bg-primary/5 hover:text-primary rounded-lg transition-colors duration-200 no-underline"
                  role="menuitem"
                >
                  {item.titulo}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      {navLinks.map(({ href, route, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors duration-300 relative group',
            currentPath === route ? 'text-primary' : 'text-gray-700 hover:text-primary'
          ]}
        >
          {label}
          <span
            class:list={[
              'absolute -bottom-1 left-0 right-0 h-0.5 bg-primary transition-transform duration-300 origin-left',
              currentPath === route ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100'
            ]}
          />
        </a>
      ))}
      <a
        href={contactoHref}
        data-booking
        class="inline-flex items-center gap-2 bg-gradient-to-br from-primary to-primary-hover
               text-white text-sm font-semibold px-4 py-2 rounded-md
               transition-all duration-300 hover:-translate-y-px hover:shadow-[0_4px_8px_rgba(0,71,171,0.3)]"
      >
        <Phone size={14} stroke-width={2} />
        Consulta Gratuita
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-gray-700 transition-all duration-300" />
      <span class="block w-6 h-0.5 bg-gray-700 transition-all duration-300" />
      <span class="block w-4 h-0.5 bg-gray-700 transition-all duration-300" />
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-100 bg-white/95 backdrop-blur-md"
  >
    <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1">
      <!-- Soluciones acordeón móvil -->
      <div class="border-b border-gray-100 pb-3">
        <button
          type="button"
          id="mobile-soluciones-btn"
          class="flex items-center justify-between w-full text-left text-base font-medium py-3 text-gray-700 hover:text-primary transition-colors"
          aria-expanded="false"
          aria-controls="mobile-soluciones-list"
        >
          Soluciones
          <ChevronDown size={18} class="transition-transform duration-200" id="mobile-soluciones-chevron" />
        </button>
        <div id="mobile-soluciones-list" class="hidden flex flex-col gap-0.5 pl-4 border-l-2 border-primary/20 mt-1">
          <a href={solucionesHref} class="block py-2 text-sm font-semibold text-primary no-underline">
            Ver todas las soluciones
          </a>
          {solucionesItems.map((item) => (
            <a
              href={withBase(`servicios/${item.id}/`)}
              class="block py-2 text-sm text-gray-600 no-underline hover:text-primary"
            >
              {item.titulo}
            </a>
          ))}
        </div>
      </div>

      {navLinks.map(({ href, route, label }) => (
        <a
          href={href}
          class:list={[
            'text-base font-medium py-3 transition-colors duration-300',
            currentPath === route ? 'text-primary' : 'text-gray-700 hover:text-primary'
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href={contactoHref}
        data-booking
        class="inline-flex items-center justify-center gap-2 bg-gradient-to-br from-primary to-primary-hover
               text-white text-sm font-semibold px-4 py-3 rounded-md mt-2
               transition-all duration-300"
      >
        <Phone size={14} stroke-width={2} />
        Consulta Gratuita
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const solucionesBtn = document.getElementById('mobile-soluciones-btn');
  const solucionesList = document.getElementById('mobile-soluciones-list');
  const solucionesChevron = document.getElementById('mobile-soluciones-chevron');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
  });

  solucionesBtn?.addEventListener('click', () => {
    const isExpanded = solucionesList?.classList.toggle('hidden') === false;
    solucionesBtn.setAttribute('aria-expanded', String(isExpanded));
    solucionesChevron?.classList.toggle('rotate-180', isExpanded);
  });
</script>
