---
/**
 * ContactoForm.astro
 * Cuestionario de Calificación — 5 preguntas + datos de contacto.
 * Tono: Profesional / Directo.
 */
import { ClipboardCheck, User, Building, Mail, Phone, Send } from 'lucide-astro';

const preguntas = [
  {
    id: 'volumen',
    num: '01',
    label: 'Volumen de Transacciones',
    question: '¿Cuál es el volumen mensual aproximado de transacciones financieras que procesa su empresa?',
    options: [
      'Menos de 100 transacciones/mes',
      '100-500 transacciones/mes',
      '500-2,000 transacciones/mes',
      'Más de 2,000 transacciones/mes',
    ],
  },
  {
    id: 'tecnologia',
    num: '02',
    label: 'Infraestructura Tecnológica Actual',
    question: '¿Cuál es el nivel de integración tecnológica de su infraestructura financiera actual?',
    options: [
      'Procesos principalmente manuales/Excel',
      'ERP básico sin integraciones',
      'ERP con algunas integraciones bancarias',
      'Infraestructura completa integrada (ERP + Bancos + CRM)',
    ],
  },
  {
    id: 'objetivo',
    num: '03',
    label: 'Objetivo Principal',
    question: '¿Cuál es el principal desafío financiero que busca resolver con TAC ADVISORS?',
    options: [
      'Reducción de errores y automatización de procesos',
      'Optimización fiscal y cumplimiento normativo',
      'Mejor visibilidad para toma de decisiones',
      'Escalamiento empresarial con infraestructura sólida',
    ],
  },
  {
    id: 'horizonte',
    num: '04',
    label: 'Tiempo Esperado',
    question: '¿En qué horizonte de tiempo espera ver resultados tangibles de nuestra colaboración?',
    options: [
      '1-3 meses (optimización inmediata)',
      '3-6 meses (transformación operativa)',
      '6-12 meses (implementación estratégica)',
      '12+ meses (cambio cultural)',
    ],
  },
  {
    id: 'compromiso',
    num: '05',
    label: 'Disponibilidad de Recursos',
    question: '¿Está dispuesto a asignar recursos internos (tiempo del equipo, acceso a sistemas) para garantizar el éxito de la implementación?',
    options: [
      'Sí, con disponibilidad limitada',
      'Sí, con disponibilidad moderada',
      'Sí, con disponibilidad completa',
      'Depende del alcance',
    ],
  },
];
---
<section id="cuestionario" class="py-20 bg-gray-50 scroll-mt-20">
  <div class="max-w-4xl mx-auto px-6">
    <!-- Header -->
    <div
      class="text-center mb-12 animate-fade-in opacity-0"
      data-animate
    >
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-6">
        <ClipboardCheck size={14} stroke-width={2} />
        Cuestionario de Calificación
      </div>

      <h2 class="font-display text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-4">
        ¿Su empresa está lista para
        <span class="text-accent">optimizar su gestión financiera</span>?
      </h2>

      <p class="text-base text-gray-600 leading-relaxed max-w-2xl mx-auto">
        Complete el siguiente cuestionario para evaluar si su empresa se ajusta a nuestros servicios.
        Este formulario nos ayuda a entender sus necesidades y determinar
        <strong class="text-gray-900">cómo podemos ayudarle mejor</strong>.
      </p>
    </div>

    <!-- Formulario -->
    <form id="qualification-form" class="space-y-0" novalidate>
      <!-- Barra de progreso -->
      <div class="mb-12">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-gray-500 font-mono">PROGRESO</span>
          <span id="progress-text" class="text-xs font-semibold text-primary font-mono">0 / 5</span>
        </div>
        <div class="h-1.5 bg-gray-200 rounded-full overflow-hidden">
          <div
            id="progress-bar"
            class="h-full bg-gradient-to-r from-primary to-accent rounded-full transition-all duration-500 ease-out"
            style="width: 0%"
          />
        </div>
      </div>

      <!-- Preguntas -->
      {preguntas.map(({ id, num, label, question, options }, i) => (
        <div
          class="bg-white border border-gray-200 rounded-xl p-6 lg:p-8 mb-4
                 transition-all duration-300
                 animate-fade-in opacity-0"
          style={`animation-delay: ${i * 80 + 100}ms`}
          data-animate
        >
          <div class="flex items-start gap-4 mb-5">
            <span class="text-3xl font-extrabold text-gray-100 font-mono leading-none shrink-0">{num}</span>
            <div>
              <p class="text-xs font-semibold text-primary uppercase tracking-widest mb-1 font-mono">{label}</p>
              <p class="text-base font-semibold text-gray-900">{question}</p>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-3 pl-0 lg:pl-12">
            {options.map((option, j) => (
              <label
                class="relative flex items-center gap-3 bg-gray-50 border border-gray-200 rounded-lg px-4 py-3
                       cursor-pointer transition-all duration-200
                       hover:border-primary/40 hover:bg-primary/5
                       has-[:checked]:border-primary has-[:checked]:bg-primary/5 has-[:checked]:shadow-sm"
              >
                <input
                  type="radio"
                  name={id}
                  value={String(j)}
                  class="w-4 h-4 text-primary border-gray-300 focus:ring-primary/20 shrink-0"
                  data-question={id}
                />
                <span class="text-sm text-gray-700 leading-snug">{option}</span>
              </label>
            ))}
          </div>
        </div>
      ))}

      <!-- Datos de contacto -->
      <div
        class="bg-white border-2 border-primary/20 rounded-xl p-6 lg:p-8 mt-8 mb-4
               animate-fade-in opacity-0"
        data-animate
      >
        <div class="flex items-start gap-4 mb-6">
          <span class="text-3xl font-extrabold text-gray-100 font-mono leading-none shrink-0">06</span>
          <div>
            <p class="text-xs font-semibold text-accent uppercase tracking-widest mb-1 font-mono">Datos de Contacto</p>
            <p class="text-base font-semibold text-gray-900">¿Cómo podemos contactarle?</p>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-4 pl-0 lg:pl-12">
          <div class="flex flex-col gap-1.5">
            <label for="nombre" class="text-sm font-medium text-gray-900 flex items-center gap-1.5">
              <User size={14} class="text-gray-400" />
              Nombre completo
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              class="w-full px-4 py-3 text-base text-gray-900
                     border border-gray-300 rounded-md bg-white
                     placeholder:text-gray-400
                     transition-all duration-300 ease-in-out
                     focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/10"
              placeholder="Juan Pérez"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="empresa" class="text-sm font-medium text-gray-900 flex items-center gap-1.5">
              <Building size={14} class="text-gray-400" />
              Empresa
            </label>
            <input
              type="text"
              id="empresa"
              name="empresa"
              required
              class="w-full px-4 py-3 text-base text-gray-900
                     border border-gray-300 rounded-md bg-white
                     placeholder:text-gray-400
                     transition-all duration-300 ease-in-out
                     focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/10"
              placeholder="Empresa SAS"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-sm font-medium text-gray-900 flex items-center gap-1.5">
              <Mail size={14} class="text-gray-400" />
              Email corporativo
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 text-base text-gray-900
                     border border-gray-300 rounded-md bg-white
                     placeholder:text-gray-400
                     transition-all duration-300 ease-in-out
                     focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/10"
              placeholder="juan@empresa.co"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="telefono" class="text-sm font-medium text-gray-900 flex items-center gap-1.5">
              <Phone size={14} class="text-gray-400" />
              Teléfono
            </label>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              class="w-full px-4 py-3 text-base text-gray-900
                     border border-gray-300 rounded-md bg-white
                     placeholder:text-gray-400
                     transition-all duration-300 ease-in-out
                     focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/10"
              placeholder="+57 300 000 0000"
            />
          </div>
        </div>
      </div>

      <!-- Botón de envío -->
      <div class="text-center pt-4">
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2
                 bg-gradient-to-br from-accent to-accent-hover
                 text-white font-semibold text-lg
                 px-10 py-4 rounded-lg
                 transition-all duration-300 ease-in-out
                 hover:-translate-y-0.5 hover:shadow-[0_8px_16px_rgba(0,212,170,0.3)]
                 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary
                 disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none"
        >
          <Send size={20} stroke-width={2} />
          Enviar Cuestionario de Calificación
        </button>
        <p class="text-xs text-gray-500 mt-3">
          Respuesta garantizada en menos de 24 horas
        </p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('qualification-form') as HTMLFormElement;
  const progressBar = document.getElementById('progress-bar') as HTMLElement;
  const progressText = document.getElementById('progress-text') as HTMLElement;
  const totalQuestions = 5;

  function updateProgress() {
    const answered = new Set(
      Array.from(form.querySelectorAll<HTMLInputElement>('input[type="radio"]:checked'))
        .map(el => el.name)
    ).size;
    const pct = (answered / totalQuestions) * 100;
    progressBar.style.width = `${pct}%`;
    progressText.textContent = `${answered} / ${totalQuestions}`;
  }

  form.addEventListener('change', updateProgress);

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const entries = Object.fromEntries(data.entries());

    if (!entries.nombre || !entries.empresa || !entries.email) {
      alert('Por favor complete los campos de nombre, empresa y email.');
      return;
    }

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.innerHTML = `
      <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      Enviando...
    `;

    setTimeout(() => {
      form.innerHTML = `
        <div class="text-center py-16">
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-accent/10 mb-6">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="22 4 12 14.01 9 11.01" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="font-display text-3xl font-bold text-gray-900 mb-4">
            Cuestionario enviado exitosamente
          </h3>
          <p class="text-lg text-gray-600 leading-relaxed max-w-lg mx-auto mb-2">
            Nuestro equipo analizará sus respuestas y le contactará dentro de
            <strong class="text-gray-900">24 horas</strong>.
          </p>
          <p class="text-sm text-gray-500">
            Si su perfil se ajusta a nuestros servicios, agendaremos una
            Auditoría Financiera gratuita.
          </p>
        </div>
      `;
    }, 1500);
  });
</script>
