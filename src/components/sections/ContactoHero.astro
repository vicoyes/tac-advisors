---
/**
 * ContactoHero.astro
 * Hero de la página Contacto — Tono Profesional / Directo.
 */
import { MessageSquare, ArrowDown } from 'lucide-astro';
---
<section class="relative py-32 pb-20 overflow-hidden bg-gradient-to-br from-gray-900 to-gray-800">
  <!-- Imagen de fondo -->
  <img
    src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1400&h=600&fit=crop&q=80"
    alt=""
    class="absolute inset-0 w-full h-full object-cover opacity-15 mix-blend-luminosity"
    loading="eager"
    aria-hidden="true"
  />

  <!-- Grid sutil -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(circle, #00D4AA 1px, transparent 1px); background-size: 48px 48px;"
    aria-hidden="true"
  />

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Copy -->
      <div>
        <div
          class="inline-flex items-center gap-2 bg-accent/10 border border-accent/20 text-accent
                 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-6
                 animate-fade-in opacity-0"
          data-animate
        >
          <MessageSquare size={14} stroke-width={2} />
          Cuestionario Inicial
        </div>

        <h1
          class="font-display text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6
                 animate-fade-in opacity-0"
          style="animation-delay: 100ms;"
          data-animate
        >
          Trabajamos con empresas que valoran la
          <span class="text-accent">eficiencia financiera.</span>
        </h1>

        <p
          class="text-lg lg:text-xl text-gray-300 leading-relaxed mb-10
                 animate-fade-in opacity-0"
          style="animation-delay: 200ms;"
          data-animate
        >
          En TAC ADVISORS, colaboramos con líderes que entienden que la inteligencia financiera
          es una <strong class="text-white">inversión estratégica</strong> para su empresa.
          Nuestro proceso de calificación nos permite enfocarnos en clientes que están
          listos para avanzar.
        </p>

        <a
          href="#cuestionario"
          class="inline-flex items-center gap-2 text-gray-400 text-sm font-medium
                 transition-colors duration-300 hover:text-accent
                 animate-fade-in opacity-0"
          style="animation-delay: 300ms;"
          data-animate
        >
          Iniciar cuestionario
          <ArrowDown size={16} stroke-width={2} class="animate-bounce" />
        </a>
      </div>

      <!-- Imagen -->
      <div
        class="hidden lg:block animate-slide-in-right opacity-0"
        style="animation-delay: 400ms;"
        data-animate
      >
        <img
          src="https://images.unsplash.com/photo-1573164713714-d95e436ab8d6?w=600&h=450&fit=crop&q=80"
          alt="Profesional en reunión estratégica de negocios"
          class="rounded-2xl object-cover w-full h-[400px] shadow-xl"
          loading="eager"
          width="600"
          height="450"
        />
      </div>
    </div>
  </div>
</section>
