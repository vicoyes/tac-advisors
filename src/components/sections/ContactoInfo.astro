---
import { CheckCircle, Mail, Phone as PhoneIcon, MapPin, Clock, Calendar, ArrowRight, Sparkles } from 'lucide-astro';
import { withBase } from '../../utils/paths';

const incluye = [
  'Revisión de su información inicial',
  'Identificación de oportunidades de mejora',
  'Orientación sobre el servicio más adecuado',
  'Recomendación de siguientes pasos',
];

const contactInfo = [
  { icon: Mail, label: 'Email', value: 'contacto@tacadvisors.co', href: 'mailto:contacto@tacadvisors.co' },
  { icon: PhoneIcon, label: 'Teléfono', value: '+57 XXX XXX XXXX', href: 'tel:+57XXXXXXXXXX' },
  { icon: MapPin, label: 'Ubicación', value: 'Bogotá, Colombia', href: null },
  { icon: Clock, label: 'Horario', value: 'Lun – Vie: 8:00 – 18:00 (GMT-5)', href: null },
];

const contactoHref = withBase('contacto/');
---

<!-- Siguiente paso -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16">
      <div class="animate-fade-in opacity-0" data-animate>
        <div class="relative mb-8">
          <img
            src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&h=360&fit=crop&q=80"
            alt="Sesión de consultoría financiera con equipo profesional"
            class="rounded-2xl object-cover w-full h-[280px] shadow-lg"
            loading="lazy"
            width="600"
            height="360"
          />
        </div>

        <div class="inline-flex items-center gap-2 bg-accent/10 text-accent px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-4">
          <Calendar size={14} stroke-width={2} />
          Siguiente Paso
        </div>

        <h3 class="font-display text-2xl lg:text-3xl font-bold text-gray-900 leading-tight mb-4">
          Sesión inicial de
          <span class="text-accent">30 minutos</span>
        </h3>

        <p class="text-base text-gray-600 leading-relaxed mb-6">
          Después de revisar su formulario, nos pondremos en contacto con usted para coordinar
          una sesión inicial gratuita y conocer mejor las necesidades de su empresa.
        </p>

        <p class="text-sm font-semibold text-gray-800 mb-4">Incluye:</p>
        <ul class="space-y-3">
          {incluye.map((item) => (
            <li class="flex items-start gap-3">
              <CheckCircle size={18} stroke-width={2} class="text-accent shrink-0 mt-0.5" />
              <span class="text-sm text-gray-700">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto directo -->
      <div class="animate-fade-in opacity-0" style="animation-delay: 200ms;" data-animate>
        <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl p-8 lg:p-10
                    border border-gray-700 overflow-hidden relative
                    before:absolute before:inset-x-0 before:top-0 before:h-1
                    before:bg-gradient-to-r before:from-primary before:to-accent">
          <div class="absolute top-0 right-0 w-1/3 h-full opacity-5 bg-gradient-to-bl from-accent to-transparent" aria-hidden="true" />

          <div class="relative z-10">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2 font-mono">
              Contacto Directo
            </p>
            <h3 class="text-2xl font-bold text-white mb-2">
              ¿Necesita contactarnos directamente?
            </h3>
            <p class="text-sm text-gray-400 leading-relaxed mb-8">
              Si prefiere escribirnos o tiene una situación puntual, también puede comunicarse
              por estos medios. De todos modos, recomendamos completar el formulario para poder
              atenderle mejor y con más contexto.
            </p>

            <div class="space-y-5">
              {contactInfo.map(({ icon: Icon, label, value, href }) => (
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center shrink-0">
                    <Icon size={18} stroke-width={1.5} class="text-accent" />
                  </div>
                  <div>
                    <p class="text-xs text-gray-500 font-mono">{label}</p>
                    {href ? (
                      <a href={href} class="text-sm font-medium text-white hover:text-accent transition-colors duration-300">
                        {value}
                      </a>
                    ) : (
                      <p class="text-sm font-medium text-white">{value}</p>
                    )}
                  </div>
                </div>
              ))}
            </div>

            <div class="h-px bg-gradient-to-r from-transparent via-gray-600 to-transparent my-8" />

            <blockquote class="text-center">
              <p class="text-sm text-gray-300 italic leading-relaxed">
                "Toda buena decisión financiera comienza con una conversación clara."
              </p>
              <p class="text-xs text-gray-500 mt-2 font-mono">— TAC ADVISORS</p>
            </blockquote>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA Final -->
<section class="relative py-16 overflow-hidden">
  <img
    src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1400&h=400&fit=crop&q=80"
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    aria-hidden="true"
  />
  <div class="absolute inset-0 bg-gray-900/90" aria-hidden="true" />
  <div class="absolute inset-0 bg-gradient-to-r from-primary/20 to-accent/10" aria-hidden="true" />

  <div class="relative z-10 max-w-3xl mx-auto px-6 text-center animate-fade-in opacity-0" data-animate>
    <p class="text-lg text-gray-300 leading-relaxed mb-6">
      Agende una consulta gratuita y conversemos sobre cómo fortalecer
      la gestión financiera de su empresa.
    </p>
    <a
      href={contactoHref}
      data-booking
      class="inline-flex items-center justify-center gap-2
             bg-gradient-to-br from-accent to-accent-hover
             text-white font-semibold text-base
             px-7 py-3.5 rounded-lg
             transition-all duration-300 ease-in-out
             hover:-translate-y-0.5 hover:shadow-[0_8px_16px_rgba(0,212,170,0.3)]"
    >
      Agendar consulta gratuita
      <ArrowRight size={18} stroke-width={2} />
    </a>
  </div>
</section>
