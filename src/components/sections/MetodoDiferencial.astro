---
/**
 * MetodoDiferencial.astro
 * Sección 4: Por qué nuestro método es diferente.
 * Transparencia Radical — Layout split con imagen.
 */
import { Eye, Clock, Zap, ArrowRight } from 'lucide-astro';

const diferenciadores = [
  {
    icon: Eye,
    title: 'Visibilidad en Tiempo Real',
    description: 'Usted ve lo que nosotros vemos, en el mismo instante. Sin esperas, sin filtros.',
  },
  {
    icon: Clock,
    title: 'Acceso 24/7',
    description: 'Su dashboard ejecutivo siempre disponible. Datos actualizados al segundo.',
  },
  {
    icon: Zap,
    title: 'Velocidad de Respuesta',
    description: 'Intervención táctica inmediata ante cualquier desviación detectada por el sistema.',
  },
];
---
<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Copy -->
      <div
        class="animate-fade-in opacity-0"
        data-animate
      >
        <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-4 font-mono">
          Nuestro Diferencial
        </p>

        <h2 class="font-display text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-6">
          Transparencia Radical y
          <span class="text-primary">Velocidad de Respuesta</span>
        </h2>

        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          A diferencia de las firmas tradicionales que le entregan balances estáticos al final del mes,
          nuestro método le otorga <strong class="text-gray-900">Soberanía Financiera</strong> todos los días.
          Usted ve lo que nosotros vemos, en el mismo instante.
        </p>

        <!-- Diferenciadores -->
        <div class="space-y-6">
          {diferenciadores.map(({ icon: Icon, title, description }) => (
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                <Icon size={22} stroke-width={1.5} class="text-primary" />
              </div>
              <div>
                <p class="text-base font-bold text-gray-900 mb-1">{title}</p>
                <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Imagen comparativa -->
      <div
        class="relative animate-slide-in-right opacity-0"
        data-animate
      >
        <img
          src="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=600&h=480&fit=crop&q=80"
          alt="Profesional monitoreando datos financieros en tiempo real con múltiples pantallas"
          class="rounded-2xl object-cover w-full h-[440px] shadow-xl"
          loading="lazy"
          width="600"
          height="480"
        />

        <!-- Comparación flotante -->
        <div class="absolute -bottom-6 left-6 right-6 grid grid-cols-2 gap-3">
          <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-lg text-center">
            <p class="text-xs text-gray-400 mb-1 font-mono">FIRMA TRADICIONAL</p>
            <p class="text-2xl font-bold text-error font-mono">30 días</p>
            <p class="text-[10px] text-gray-500">Reporte mensual</p>
          </div>
          <div class="bg-white border-2 border-accent rounded-xl p-4 shadow-lg text-center">
            <p class="text-xs text-gray-400 mb-1 font-mono">TAC ADVISORS</p>
            <p class="text-2xl font-bold text-accent font-mono">Tiempo real</p>
            <p class="text-[10px] text-gray-500">Dashboard 24/7</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
