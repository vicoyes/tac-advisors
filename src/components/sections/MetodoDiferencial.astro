---
import { CheckCircle2, Calculator, Scale, Monitor, Brain, Users } from 'lucide-astro';

const enfoques = [
  { icon: Calculator, texto: 'Rigor contable y financiero' },
  { icon: Scale, texto: 'Conocimiento tributario' },
  { icon: Monitor, texto: 'Tecnología aplicada a procesos' },
  { icon: Brain, texto: 'Análisis de datos con apoyo de IA' },
  { icon: Users, texto: 'Acompañamiento humano y criterio estratégico' },
];
---
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Imagen -->
      <div class="relative animate-slide-in-left opacity-0" data-animate>
        <img
          src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=640&h=480&fit=crop&q=80"
          alt="Equipo de profesionales analizando datos financieros"
          class="rounded-2xl object-cover w-full h-[420px] shadow-xl"
          loading="lazy"
          width="640"
          height="480"
        />
        <div class="absolute -bottom-5 -right-5 bg-white border-2 border-accent rounded-xl p-4 shadow-lg">
          <p class="text-xs text-gray-500 font-mono uppercase tracking-wider">Nuestro enfoque</p>
          <p class="text-lg font-bold text-accent font-mono">Datos + Criterio</p>
        </div>
      </div>

      <!-- Contenido -->
      <div class="animate-fade-in opacity-0" data-animate>
        <div class="inline-flex items-center gap-2 bg-accent/10 text-accent px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-4">
          Diferencial
        </div>

        <h2 class="font-display text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-6">
          La diferencia no está solo en los números, sino en
          <span class="text-accent">cómo los interpretamos</span>
        </h2>

        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          No nos limitamos a registrar información. La organizamos, la analizamos y la convertimos
          en criterios útiles para la dirección del negocio.
        </p>

        <p class="text-base font-semibold text-gray-800 mb-5">Nuestro enfoque combina:</p>

        <div class="space-y-3">
          {enfoques.map((e) => (
            <div class="flex items-center gap-3 bg-gray-50 border border-gray-100 rounded-lg px-4 py-3
                        transition-all duration-300 hover:border-accent/30 hover:bg-accent/5">
              <e.icon size={20} stroke-width={1.5} class="text-accent shrink-0" />
              <span class="text-base text-gray-700 font-medium">{e.texto}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
