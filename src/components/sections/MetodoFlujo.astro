---
import { Search, FolderSync, LineChart, Rocket, RefreshCw } from 'lucide-astro';

const pasos = [
  {
    num: '01',
    icon: Search,
    titulo: 'Diagnóstico inicial',
    descripcion: 'Revisamos el estado contable, tributario y financiero de su empresa para identificar riesgos, oportunidades de mejora y necesidades prioritarias.',
  },
  {
    num: '02',
    icon: FolderSync,
    titulo: 'Organización e integración de la información',
    descripcion: 'Consolidamos la información relevante de su operación y mejoramos la forma en que se captura, procesa y utiliza.',
  },
  {
    num: '03',
    icon: LineChart,
    titulo: 'Análisis y criterios de decisión',
    descripcion: 'Aplicamos herramientas de análisis y apoyo tecnológico para interpretar los datos, detectar patrones y convertir la información en recomendaciones concretas.',
  },
  {
    num: '04',
    icon: Rocket,
    titulo: 'Implementación',
    descripcion: 'Ponemos en marcha los ajustes, mejoras y estrategias acordadas según los objetivos del negocio.',
  },
  {
    num: '05',
    icon: RefreshCw,
    titulo: 'Seguimiento y acompañamiento',
    descripcion: 'Damos continuidad al proceso para que su empresa mantenga control, cumplimiento y una visión financiera más útil para crecer.',
  },
];
---
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16 animate-fade-in opacity-0" data-animate>
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-4">
        Proceso
      </div>
      <h2 class="font-display text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-4">
        Nuestra <span class="text-primary">metodología</span> de trabajo
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed">
        Trabajamos con un proceso estructurado que nos permite comprender la realidad de su empresa,
        ordenar la información financiera y convertirla en una base sólida para tomar decisiones.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative max-w-4xl mx-auto">
      <div class="absolute left-6 lg:left-1/2 lg:-translate-x-px top-0 bottom-0 w-0.5 bg-gray-200" aria-hidden="true" />

      {pasos.map((p, i) => (
        <div
          class:list={[
            'relative grid lg:grid-cols-2 gap-8 mb-12 last:mb-0 animate-fade-in opacity-0',
            i % 2 === 0 ? '' : 'lg:direction-rtl'
          ]}
          style={`animation-delay: ${i * 120}ms;`}
          data-animate
        >
          {/* Dot on timeline */}
          <div class="absolute left-6 lg:left-1/2 -translate-x-1/2 w-12 h-12 rounded-full bg-white border-2 border-primary
                      flex items-center justify-center z-10 shadow-md">
            <span class="text-sm font-bold text-primary font-mono">{p.num}</span>
          </div>

          {/* Content card */}
          <div class:list={[
            'ml-16 lg:ml-0',
            i % 2 === 0 ? 'lg:pr-12 lg:text-right' : 'lg:col-start-2 lg:pl-12'
          ]}>
            <div class="bg-gray-50 border border-gray-100 rounded-xl p-6 transition-all duration-300
                        hover:border-primary/30 hover:shadow-md">
              <div class:list={[
                'flex items-center gap-3 mb-3',
                i % 2 === 0 ? 'lg:flex-row-reverse' : ''
              ]}>
                <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                  <p.icon size={20} stroke-width={1.5} class="text-primary" />
                </div>
                <h3 class="text-lg font-bold text-gray-900">{p.titulo}</h3>
              </div>
              <p class="text-sm text-gray-600 leading-relaxed">{p.descripcion}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
