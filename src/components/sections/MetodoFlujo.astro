---
/**
 * MetodoFlujo.astro
 * Sección 3: Flujo de Trabajo — Timeline de 4 fases.
 * Fondo oscuro técnico con timeline vertical.
 */
import { Download, Sparkles, UserCheck, Monitor } from 'lucide-astro';

const fases = [
  {
    icon: Download,
    num: '01',
    title: 'Ingesta Automatizada',
    description: 'Recibimos sus datos financieros de forma segura y encriptada (Nivel Bancario).',
    accent: 'primary' as const,
  },
  {
    icon: Sparkles,
    num: '02',
    title: 'Orquestación y Limpieza',
    description: 'La IA procesa, limpia y organiza la información, asegurando la integridad de los datos.',
    accent: 'accent' as const,
  },
  {
    icon: UserCheck,
    num: '03',
    title: 'Intervención Experta',
    description: 'Nuestros especialistas financieros auditan el output de la IA, añadiendo la capa de criterio estratégico que solo el talento humano de élite puede proveer.',
    accent: 'primary' as const,
  },
  {
    icon: Monitor,
    num: '04',
    title: 'Entrega de Valor',
    description: 'Usted recibe claridad estratégica inmediata para tomar la siguiente gran decisión de su empresa.',
    accent: 'accent' as const,
  },
];

const accentMap = {
  primary: { dot: 'bg-primary', iconBg: 'bg-primary/20', iconColor: 'text-primary', line: 'from-primary' },
  accent:  { dot: 'bg-accent',  iconBg: 'bg-accent/20',  iconColor: 'text-accent',  line: 'from-accent' },
};
---
<section class="py-20 bg-gradient-to-br from-gray-800 to-gray-900 text-white">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div
      class="max-w-3xl mx-auto text-center mb-16
             animate-fade-in opacity-0"
      data-animate
    >
      <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-4 font-mono">
        De la Transacción al Insight
      </p>
      <h2 class="font-display text-4xl lg:text-5xl font-bold text-white leading-tight">
        Un Ciclo de Inteligencia Financiera
        <span class="text-accent">Continua</span>
      </h2>
    </div>

    <!-- Layout: Imagen + Timeline -->
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Imagen -->
      <div
        class="relative animate-slide-in-left opacity-0"
        data-animate
      >
        <img
          src="https://images.unsplash.com/photo-1504868584819-f8e8b4b6d7e3?w=600&h=500&fit=crop&q=80"
          alt="Flujo de datos y análisis en pantallas de monitoreo"
          class="rounded-2xl object-cover w-full h-[480px] shadow-2xl"
          loading="lazy"
          width="600"
          height="500"
        />
        <!-- Overlay con dato -->
        <div class="absolute bottom-6 left-6 right-6 bg-white/10 backdrop-blur-md border border-white/10 rounded-xl p-4">
          <div class="flex items-center gap-4">
            <div class="h-12 w-1 bg-gradient-to-b from-primary to-accent rounded-full" />
            <div>
              <p class="text-sm font-bold text-white">Ciclo continuo 24/7</p>
              <p class="text-xs text-gray-400">Datos procesados en tiempo real, sin interrupciones</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Timeline vertical -->
      <div class="relative">
        {/* Línea vertical */}
        <div
          class="absolute left-5 top-0 bottom-0 w-px bg-gradient-to-b from-primary via-accent to-primary/30"
          aria-hidden="true"
        />

        <div class="space-y-10">
          {fases.map(({ icon: Icon, num, title, description, accent }, i) => {
            const s = accentMap[accent];
            return (
              <div
                class="relative pl-14 animate-fade-in opacity-0"
                style={`animation-delay: ${i * 150 + 100}ms`}
                data-animate
              >
                {/* Dot en la línea */}
                <div class:list={[
                  'absolute left-0 top-1 w-10 h-10 rounded-xl flex items-center justify-center',
                  s.iconBg
                ]}>
                  <Icon size={20} stroke-width={1.5} class={s.iconColor} />
                </div>

                {/* Contenido */}
                <div>
                  <span class:list={['text-xs font-bold font-mono uppercase tracking-widest', s.iconColor]}>
                    Fase {num}
                  </span>
                  <h3 class="text-xl font-bold text-white mt-1 mb-2">{title}</h3>
                  <p class="text-base text-gray-400 leading-relaxed">{description}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>
