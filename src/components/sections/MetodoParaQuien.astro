---
import { TrendingUp, RefreshCw, Eye, Handshake } from 'lucide-astro';

const perfiles = [
  {
    icon: TrendingUp,
    texto: 'Han crecido y necesitan ordenar su operación financiera',
  },
  {
    icon: RefreshCw,
    texto: 'Quieren dejar atrás procesos manuales e ineficientes',
  },
  {
    icon: Eye,
    texto: 'Necesitan una visión más clara para decidir mejor',
  },
  {
    icon: Handshake,
    texto: 'Buscan un aliado que combine análisis técnico y visión de negocio',
  },
];
---
<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-3xl mx-auto text-center mb-14 animate-fade-in opacity-0" data-animate>
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-4">
        Para Quién Es
      </div>
      <h2 class="font-display text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-4">
        Trabajamos con empresas que necesitan
        <span class="text-primary">más claridad y mejor control</span>
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed">
        Nuestros servicios están pensados para organizaciones que:
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
      {perfiles.map((p, i) => (
        <div
          class="group bg-white border border-gray-200 rounded-xl p-6 text-center
                 transition-all duration-300 hover:border-primary/40 hover:shadow-lg hover:-translate-y-1
                 animate-fade-in opacity-0"
          style={`animation-delay: ${i * 100}ms;`}
          data-animate
        >
          <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4
                      transition-transform duration-300 group-hover:scale-110">
            <p.icon size={26} stroke-width={1.5} class="text-primary" />
          </div>
          <p class="text-base text-gray-700 font-medium leading-relaxed">{p.texto}</p>
        </div>
      ))}
    </div>
  </div>
</section>
