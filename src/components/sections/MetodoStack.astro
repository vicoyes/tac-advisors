---
/**
 * MetodoStack.astro
 * Sección 2: El Stack Tecnológico — 4 elementos.
 * Layout: grid de 4 cards técnicas con imágenes.
 */
import { Unplug, BrainCircuit, LineChart, LayoutDashboard } from 'lucide-astro';

const elementos = [
  {
    icon: Unplug,
    num: '01',
    title: 'Integración de Datos',
    subtitle: 'ERP + Bancos + CRM',
    description: 'Conexión vía API y conectores nativos para recolectar información en tiempo real sin intervención humana.',
    image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=400&h=240&fit=crop&q=80',
    imageAlt: 'Infraestructura de servidores y conexiones de datos',
    accent: 'primary' as const,
  },
  {
    icon: BrainCircuit,
    num: '02',
    title: 'Motor de Procesamiento IA',
    subtitle: 'Clasificación Inteligente',
    description: 'Nuestros algoritmos clasifican transacciones, detectan patrones y categorizan costos con una precisión del 99.9%, eliminando el sesgo del error humano.',
    image: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?w=400&h=240&fit=crop&q=80',
    imageAlt: 'Inteligencia artificial procesando datos financieros',
    accent: 'accent' as const,
  },
  {
    icon: LineChart,
    num: '03',
    title: 'Análisis Predictivo',
    subtitle: 'Modelos Matemáticos',
    description: 'Modelos matemáticos que proyectan su flujo de caja y detectan desviaciones presupuestarias antes de que ocurran.',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=400&h=240&fit=crop&q=80',
    imageAlt: 'Gráficos de análisis predictivo y proyecciones financieras',
    accent: 'primary' as const,
  },
  {
    icon: LayoutDashboard,
    num: '04',
    title: 'Dashboard Ejecutivo',
    subtitle: 'C-Suite Interface',
    description: 'Visualización de KPIs críticos en tiempo real, diseñada para líderes que necesitan datos, no solo números.',
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=400&h=240&fit=crop&q=80',
    imageAlt: 'Dashboard ejecutivo con KPIs financieros en pantalla',
    accent: 'accent' as const,
  },
];

const accentMap = {
  primary: { badge: 'bg-primary text-white', iconBg: 'bg-primary/10', iconColor: 'text-primary', num: 'text-primary' },
  accent:  { badge: 'bg-accent text-white',  iconBg: 'bg-accent/10',  iconColor: 'text-accent',  num: 'text-accent' },
};
---
<section id="stack" class="py-20 bg-white scroll-mt-20">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div
      class="max-w-3xl mx-auto text-center mb-16
             animate-fade-in opacity-0"
      data-animate
    >
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-4 font-mono">
        El Motor de Inteligencia Operativa
      </p>
      <h2 class="font-display text-4xl lg:text-5xl font-bold text-gray-900 leading-tight">
        Nuestra Caja de Herramientas
        <span class="text-primary">de Élite</span>
      </h2>
    </div>

    <!-- Grid de 4 elementos -->
    <div class="grid md:grid-cols-2 gap-8">
      {elementos.map(({ icon: Icon, num, title, subtitle, description, image, imageAlt, accent }, i) => {
        const s = accentMap[accent];
        return (
          <div
            class="bg-white border border-gray-200 rounded-xl overflow-hidden
                   shadow-sm transition-all duration-300
                   hover:shadow-xl hover:-translate-y-1
                   animate-fade-in opacity-0"
            style={`animation-delay: ${i * 100 + 100}ms`}
            data-animate
          >
            {/* Imagen */}
            <div class="relative h-48 overflow-hidden">
              <img
                src={image}
                alt={imageAlt}
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
                loading="lazy"
                width="400"
                height="240"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent" />
              {/* Número */}
              <span class="absolute top-4 left-4 text-5xl font-extrabold text-white/20 font-mono leading-none">
                {num}
              </span>
              {/* Badge icono */}
              <div class:list={['absolute bottom-4 left-4 w-10 h-10 rounded-lg flex items-center justify-center shadow-md', s.badge]}>
                <Icon size={20} stroke-width={1.5} class="text-white" />
              </div>
            </div>

            {/* Contenido */}
            <div class="p-6">
              <p class:list={['text-xs font-semibold uppercase tracking-widest mb-1 font-mono', s.num]}>
                {subtitle}
              </p>
              <h3 class="text-xl font-bold text-gray-900 mb-3">{title}</h3>
              <p class="text-base text-gray-600 leading-relaxed">{description}</p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
