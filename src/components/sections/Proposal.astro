---
import { Eye, BrainCircuit, ShieldCheck, ArrowRight } from 'lucide-astro';
import { withBase } from '../../utils/paths';

const features = [
  {
    icon: Eye,
    title: 'Visión más clara del negocio',
    description: 'Integramos información financiera y operativa para reducir puntos ciegos, mejorar la lectura del negocio y facilitar decisiones más informadas.',
    accent: 'primary' as const,
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&h=340&fit=crop&q=80',
    imageAlt: 'Dashboard con métricas financieras integradas',
  },
  {
    icon: BrainCircuit,
    title: 'Análisis con apoyo tecnológico',
    description: 'Utilizamos tecnología e inteligencia artificial como apoyo para detectar patrones, oportunidades de mejora y señales de riesgo que merecen atención.',
    accent: 'accent' as const,
    image: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?w=600&h=340&fit=crop&q=80',
    imageAlt: 'Inteligencia artificial aplicada al análisis financiero',
  },
  {
    icon: ShieldCheck,
    title: 'Control y criterio para decidir',
    description: 'Convertimos la información en insumos más claros para la dirección de la empresa, con un enfoque en control, orden y toma de decisiones.',
    accent: 'primary' as const,
    image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600&h=340&fit=crop&q=80',
    imageAlt: 'Control financiero con procesos organizados',
  },
];

const accentStyles = {
  primary: {
    border: 'hover:border-primary',
    shadow: 'hover:shadow-[0_12px_24px_rgba(0,71,171,0.15)]',
    badge: 'bg-primary text-white',
  },
  accent: {
    border: 'hover:border-accent',
    shadow: 'hover:shadow-[0_12px_24px_rgba(0,212,170,0.15)]',
    badge: 'bg-accent text-white',
  },
};

const solucionesHref = withBase('soluciones/');
---
<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div
      class="max-w-3xl mx-auto text-center mb-16 animate-fade-in opacity-0"
      data-animate
    >
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-4">
        Propuesta de Valor
      </p>
      <h2 class="font-display text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-6">
        Una nueva forma de fortalecer la
        <span class="text-accent">gestión financiera</span> de su empresa
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {features.map(({ icon: Icon, title, description, accent, image, imageAlt }, i) => {
        const styles = accentStyles[accent];
        return (
          <div
            class:list={[
              'relative bg-white border-2 border-gray-200 rounded-xl',
              'overflow-hidden transition-all duration-300 ease-in-out',
              styles.border, styles.shadow,
              'hover:-translate-y-1',
              'animate-fade-in opacity-0',
            ]}
            style={`animation-delay: ${i * 150 + 100}ms`}
            data-animate
          >
            <div class="relative h-48 overflow-hidden bg-gray-200">
              <img
                src={image}
                alt={imageAlt}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 hover:scale-105"
                loading="lazy"
                width="400"
                height="192"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-gray-50 via-white/30 to-transparent pointer-events-none" aria-hidden="true" />
              <div class:list={[
                'absolute bottom-3 left-6 w-12 h-12 rounded-xl flex items-center justify-center shadow-md',
                styles.badge,
              ]}>
                <Icon size={22} stroke-width={1.5} class="text-white" />
              </div>
            </div>

            <div class="p-6 pt-4">
              <h3 class="text-xl font-bold text-gray-900 mb-3">{title}</h3>
              <p class="text-base text-gray-600 leading-relaxed">{description}</p>
            </div>
          </div>
        );
      })}
    </div>

    <div class="text-center mt-12 animate-fade-in opacity-0" data-animate>
      <a
        href={solucionesHref}
        class="inline-flex items-center gap-2 text-primary font-semibold text-base
               transition-all duration-300 hover:gap-3"
      >
        Explorar todas las soluciones
        <ArrowRight size={18} stroke-width={2} />
      </a>
    </div>
  </div>
</section>
