---
/**
 * RecursosHero.astro
 * Hero de la página Recursos/Blog.
 * Balance: 65% técnico / 35% innovador.
 */
import { BookOpen } from 'lucide-astro';

const categorias = [
  { label: 'Todos', value: 'all', active: true },
  { label: 'Inteligencia Financiera', value: 'financial' },
  { label: 'Optimización Fiscal', value: 'tax' },
  { label: 'Tecnología', value: 'tech' },
  { label: 'Tendencias', value: 'trends' },
];
---
<section class="relative py-28 pb-16 overflow-hidden bg-gradient-to-br from-gray-900 to-gray-800">
  <!-- Imagen de fondo -->
  <img
    src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=1400&h=500&fit=crop&q=80"
    alt=""
    class="absolute inset-0 w-full h-full object-cover opacity-10 mix-blend-luminosity"
    loading="eager"
    aria-hidden="true"
  />

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="max-w-3xl mx-auto text-center">
      <div
        class="inline-flex items-center gap-2 bg-accent/10 border border-accent/20 text-accent
               px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-6
               animate-fade-in opacity-0"
        data-animate
      >
        <BookOpen size={14} stroke-width={2} />
        Centro de Recursos
      </div>

      <h1
        class="font-display text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6
               animate-fade-in opacity-0"
        style="animation-delay: 100ms;"
        data-animate
      >
        Insights para líderes que
        <span class="text-accent">deciden con datos</span>
      </h1>

      <p
        class="text-lg text-gray-300 leading-relaxed mb-10
               animate-fade-in opacity-0"
        style="animation-delay: 200ms;"
        data-animate
      >
        Análisis técnicos, tendencias del mercado y guías estratégicas publicadas
        por nuestro equipo de inteligencia financiera.
      </p>

      <!-- Filtros de categoría -->
      <div
        class="flex flex-wrap justify-center gap-2
               animate-fade-in opacity-0"
        style="animation-delay: 300ms;"
        data-animate
      >
        {categorias.map(({ label, active }) => (
          <button
            class:list={[
              'px-4 py-2 rounded-full text-sm font-medium transition-all duration-300',
              active
                ? 'bg-accent text-white shadow-[0_4px_12px_rgba(0,212,170,0.3)]'
                : 'bg-white/10 text-gray-300 hover:bg-white/20 hover:text-white'
            ]}
          >
            {label}
          </button>
        ))}
      </div>
    </div>
  </div>
</section>
