---
import {
  Calculator,
  Scale,
  Users,
  Zap,
  PieChart,
  BookMarked,
  ShieldCheck,
  BarChart3,
  Landmark,
  Monitor,
  ClipboardCheck,
  ChevronDown,
  CheckCircle2,
} from 'lucide-astro';

const servicios = [
  {
    id: 'outsourcing-contable',
    icon: Calculator,
    color: 'primary',
    titulo: 'Outsourcing Contable',
    headline: 'Contabilidad como Servicio: Precisión Operativa y Cumplimiento Normativo',
    descripcion: 'Implementamos un modelo de gestión integral que cubre desde el registro diario de transacciones hasta la preparación de informes consolidados, garantizando que sus libros contables cumplan con los más altos estándares de calidad y normatividad vigente.',
    detalle: 'Este servicio elimina la fricción operativa interna, permitiendo que su equipo se concentre en actividades de mayor valor mientras nosotros asumimos la responsabilidad de mantener una contabilidad impecable, auditada y lista para cualquier requerimiento financiero.',
    puntos: [
      { titulo: 'Registro Integral', desc: 'Captura y clasificación diaria de todas las transacciones con criterios contables rigurosos.' },
      { titulo: 'Cumplimiento Normativo', desc: 'Alineación permanente con regulaciones contables colombianas e internacionales.' },
      { titulo: 'Soporte Auditoría', desc: 'Documentación estructurada y listos para auditorías externas o requerimientos de control.' },
    ],
  },
  {
    id: 'asesoria-tributaria',
    icon: Scale,
    color: 'accent',
    titulo: 'Asesoría Tributaria y Planeación Fiscal',
    headline: 'Excelencia Fiscal: Optimización con Seguridad Jurídica',
    descripcion: 'Combinamos el cumplimiento normativo con una planeación fiscal proactiva que identifica oportunidades legítimas de optimización, siempre dentro del marco regulatorio vigente.',
    detalle: 'Desarrollamos escenarios fiscales que anticipan impactos tributarios de sus decisiones de inversión, operaciones o reestructuraciones empresariales. Nuestro equipo mantiene actualización continua frente a reformas tributarias, jurisprudencia y directrices de la DIAN.',
    puntos: [
      { titulo: 'Planeación Continua', desc: 'Modelos tributarios dinámicos que se ajustan a su evolución empresarial.' },
      { titulo: 'Actualización Regulatoria', desc: 'Monitoreo permanente de cambios legislativos y jurisprudenciales relevantes.' },
      { titulo: 'Optimización Legítima', desc: 'Identificación de beneficios y deducciones aplicables sin comprometer el cumplimiento.' },
    ],
  },
  {
    id: 'gestion-nomina',
    icon: Users,
    color: 'primary',
    titulo: 'Gestión de Nómina y Prestaciones',
    headline: 'Compensaciones Precisas: Gestión Integral de Recursos Humanos',
    descripcion: 'Nuestro servicio integral cubre desde el cálculo y procesamiento de nómina hasta la liquidación de prestaciones sociales, aportes parafiscales y todas las obligaciones derivadas de la relación laboral, garantizando cero errores y cumplimiento total.',
    detalle: 'Implementamos controles de calidad automatizados que detectan inconsistencias antes de la generación de pagos, protegiendo tanto al empleador como a los colaboradores.',
    puntos: [
      { titulo: 'Cálculo Riguroso', desc: 'Procesamiento con validación múltiple de todas las deducciones y aportes.' },
      { titulo: 'Cumplimiento Laboral', desc: 'Alineación con normativa vigente y actualización ante cambios en la legislación.' },
      { titulo: 'Reportes Estratégicos', desc: 'Análisis de costos laborales y proyecciones para toma de decisiones gerenciales.' },
    ],
  },
  {
    id: 'facturacion-electronica',
    icon: Zap,
    color: 'accent',
    titulo: 'Facturación Electrónica (DIAN)',
    headline: 'Conectividad Fiscal: Integración Total con la DIAN',
    descripcion: 'Implementamos soluciones integrales que conectan sus sistemas operativos con la plataforma de facturación electrónica de la DIAN, garantizando la emisión, transmisión, validación y almacenamiento de facturas con total conformidad regulatoria.',
    detalle: 'Nuestra implementación incluye la configuración de catálogos, gestión de notas crédito y débito, emisión de documentos soporte y la interoperabilidad con sistemas ERP y contables.',
    puntos: [
      { titulo: 'Integración ERP', desc: 'Conexión directa entre sus sistemas operativos y la plataforma de la DIAN.' },
      { titulo: 'Validación en Tiempo Real', desc: 'Detección anticipada de rechazos y contingencias operativas.' },
      { titulo: 'Almacenamiento Normativo', desc: 'Gestión documental compliant con requisitos de conservación y disponibilidad.' },
    ],
  },
  {
    id: 'estados-financieros',
    icon: PieChart,
    color: 'primary',
    titulo: 'Estados Financieros e Interpretación',
    headline: 'Radiografía Financiera: Del Registro a la Inteligencia',
    descripcion: 'Preparamos estados financieros completos bajo estándares internacionales, incluyendo análisis e interpretación que transforma datos en insights accionables sobre rentabilidad, solvencia, eficiencia operativa y posicionamiento financiero.',
    detalle: 'Nuestro análisis incluye comparativas históricas, benchmarking sectorial, identificación de tendencias y alertas tempranas sobre riesgos financieros o áreas de mejora.',
    puntos: [
      { titulo: 'Análisis Integral', desc: 'Estados financieros completos con interpretación técnica y narrativa.' },
      { titulo: 'Benchmarking', desc: 'Comparativas con referencias sectoriales y estándares de desempeño.' },
      { titulo: 'Alertas Estratégicas', desc: 'Identificación proactiva de riesgos financieros y oportunidades de mejora.' },
    ],
  },
  {
    id: 'niif-pymes',
    icon: BookMarked,
    color: 'accent',
    titulo: 'NIIF para PyMEs 2027',
    headline: 'Convergencia Normativa: Transición a NIIF con Claridad',
    descripcion: 'Ofrecemos acompañamiento integral desde el diagnóstico de impacto normativo hasta la implementación completa, asegurando una transición fluida que no interrumpa sus operaciones ni afecte la calidad de su información financiera.',
    detalle: 'Nuestra metodología incluye la identificación de políticas contables que requieren cambios, el rediseño de procesos de registro y reporte, y la generación de información comparativa bajo los nuevos estándares.',
    puntos: [
      { titulo: 'Diagnóstico de Impacto', desc: 'Evaluación detallada de cambios requeridos en políticas y procesos.' },
      { titulo: 'Implementación Gradual', desc: 'Plan de transición estructurado sin interrupciones operativas.' },
      { titulo: 'Capacitación Integral', desc: 'Formación de equipos para manejo autónomo bajo estándares NIIF.' },
    ],
  },
  {
    id: 'revisoria-fiscal',
    icon: ShieldCheck,
    color: 'primary',
    titulo: 'Revisoría Fiscal',
    headline: 'Control Independiente: Confianza y Transparencia Garantizada',
    descripcion: 'Actuamos como revisores fiscales independientes con rigor técnico, imparcialidad absoluta y un enfoque que agrega valor más allá de la certificación de cumplimiento.',
    detalle: 'Nuestra revisoría incluye la evaluación de la calidad de los estados financieros, verificación del cumplimiento tributario y laboral, e identificación de riesgos de control con emisión de informes constructivos.',
    puntos: [
      { titulo: 'Independencia Técnica', desc: 'Evaluación objetiva sin conflictos de interés.' },
      { titulo: 'Valor Agregado', desc: 'Informes con observaciones y recomendaciones accionables.' },
      { titulo: 'Alertas Tempranas', desc: 'Identificación proactiva de riesgos y áreas de mejora en controles.' },
    ],
  },
  {
    id: 'analisis-financiero',
    icon: BarChart3,
    color: 'accent',
    titulo: 'Análisis Financiero Estratégico',
    headline: 'Inteligencia de Negocio: Decisiones Basadas en Datos',
    descripcion: 'Desarrollamos modelos analíticos que combinan estados financieros, indicadores de desempeño, proyecciones de flujo de caja y escenarios de negocio para una visión integral de su posición competitiva.',
    detalle: 'Incluye evaluación de rentabilidad por líneas de negocio, análisis de estructura de capital, evaluación de proyectos de inversión y modelado de escenarios con recomendaciones estratégicas.',
    puntos: [
      { titulo: 'Modelos Dinámicos', desc: 'Herramientas analíticas para simulación de escenarios y decisiones.' },
      { titulo: 'Rentabilidad Segmentada', desc: 'Análisis de desempeño por líneas de negocio, productos o unidades.' },
      { titulo: 'Fundamentación Cuantitativa', desc: 'Recomendaciones estratégicas respaldadas en datos sólidos.' },
    ],
  },
  {
    id: 'constitucion-empresa',
    icon: Landmark,
    color: 'primary',
    titulo: 'Constitución de Empresa',
    headline: 'Fundamentos Sólidos: Estructuración Empresarial Ética',
    descripcion: 'Servicio integral desde la definición del tipo societario más adecuado hasta el registro completo ante cámaras de comercio, DIAN y entidades correspondientes.',
    detalle: 'Incluye redacción de estatutos sociales, definición de regímenes tributarios óptimos, configuración de estructuras de capital y la implementación de libros contables desde el día uno.',
    puntos: [
      { titulo: 'Estructuración Integral', desc: 'Definición de tipo societario y régimen tributario según objetivos del negocio.' },
      { titulo: 'Registro Completo', desc: 'Gestión de todos los trámites ante cámaras de comercio y DIAN.' },
      { titulo: 'Arranque Contable', desc: 'Implementación de libros y procesos contables desde la constitución.' },
    ],
  },
  {
    id: 'transformacion-digital',
    icon: Monitor,
    color: 'accent',
    titulo: 'Transformación Digital Contable',
    headline: 'Evolución Operativa: Contabilidad Digital y Eficiente',
    descripcion: 'Diseñamos e implementamos soluciones digitales que integran sistemas de contabilidad, bancos, facturación y herramientas operativas en un ecosistema conectado que automatiza tareas repetitivas.',
    detalle: 'Incluye diagnóstico de procesos actuales, selección e implementación de herramientas digitales, integración mediante APIs, migración de datos históricos y capacitación de equipos.',
    puntos: [
      { titulo: 'Integración de Sistemas', desc: 'Conexión entre contabilidad, bancos y herramientas operativas.' },
      { titulo: 'Automatización de Procesos', desc: 'Eliminación de tareas manuales y reducción de errores.' },
      { titulo: 'Información en Tiempo Real', desc: 'Capacidad de generar reportes financieros con latencia mínima.' },
    ],
  },
  {
    id: 'auditoria-aseguramiento',
    icon: ClipboardCheck,
    color: 'primary',
    titulo: 'Auditoría y Aseguramiento',
    headline: 'Garantía de Calidad: Confianza y Cumplimiento Verificado',
    descripcion: 'Realizamos auditorías financieras, revisiones especiales y procedimientos de aseguramiento bajo estándares profesionales internacionales, entregando informes que aportan valor más allá de la opinión de auditoría.',
    detalle: 'Incluye evaluación de sistemas de control interno, verificación del cumplimiento normativo, identificación de riesgos operativos y financieros, y recomendaciones para fortalecer la gestión de riesgos.',
    puntos: [
      { titulo: 'Estándares Internacionales', desc: 'Auditorías bajo normas de auditoría aceptadas globalmente.' },
      { titulo: 'Mejora Continua', desc: 'Recomendaciones para fortalecer controles y procesos internos.' },
      { titulo: 'Independencia y Confianza', desc: 'Evaluación objetiva que genera credibilidad con stakeholders.' },
    ],
  },
];
---

<section class="py-20 bg-gray-50" id="servicios">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div
      class="text-center max-w-3xl mx-auto mb-16 animate-fade-in opacity-0"
      data-animate
    >
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-4">
        Portafolio Integral
      </div>
      <h2 class="font-display text-3xl lg:text-5xl font-bold text-gray-900 leading-tight mb-4">
        11 Servicios. <span class="text-primary">Una Visión.</span>
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed">
        Cada servicio opera como un módulo especializado que se integra a su infraestructura existente.
        Seleccione lo que necesita o active un ecosistema completo.
      </p>
    </div>

    <!-- Grid de servicios -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {servicios.map((s, i) => (
        <div
          class="group servicio-card bg-white border border-gray-200 rounded-xl overflow-hidden
                 transition-all duration-300 hover:border-primary/40 hover:shadow-[0_8px_24px_rgba(0,71,171,0.1)]
                 animate-fade-in opacity-0 flex flex-col"
          style={`animation-delay: ${(i % 6) * 80}ms;`}
          data-animate
          data-servicio={s.id}
        >
          <!-- Barra de color superior -->
          <div class:list={[
            'h-1 w-full transition-all duration-300',
            s.color === 'accent' ? 'bg-accent group-hover:h-1.5' : 'bg-primary group-hover:h-1.5'
          ]} />

          <div class="p-6 flex flex-col flex-1">
            <!-- Icono + título -->
            <div class="flex items-start gap-4 mb-4">
              <div class:list={[
                'w-12 h-12 rounded-xl flex items-center justify-center shrink-0 transition-transform duration-300 group-hover:scale-110',
                s.color === 'accent' ? 'bg-accent/10 text-accent' : 'bg-primary/10 text-primary'
              ]}>
                <s.icon size={24} stroke-width={1.5} />
              </div>
              <div class="min-w-0">
                <h3 class="text-lg font-bold text-gray-900 leading-snug">{s.titulo}</h3>
                <p class:list={[
                  'text-xs font-semibold uppercase tracking-wider mt-0.5',
                  s.color === 'accent' ? 'text-accent' : 'text-primary'
                ]}>{s.headline.split(':')[0]}</p>
              </div>
            </div>

            <!-- Descripción -->
            <p class="text-sm text-gray-600 leading-relaxed mb-4 flex-1">
              {s.descripcion}
            </p>

            <!-- Puntos clave (siempre visibles) -->
            <div class="space-y-2 mb-4">
              {s.puntos.map((p) => (
                <div class="flex items-start gap-2">
                  <CheckCircle2
                    size={16}
                    stroke-width={2}
                    class:list={[
                      'shrink-0 mt-0.5',
                      s.color === 'accent' ? 'text-accent' : 'text-primary'
                    ]}
                  />
                  <div>
                    <span class="text-sm font-semibold text-gray-800">{p.titulo}: </span>
                    <span class="text-sm text-gray-500">{p.desc}</span>
                  </div>
                </div>
              ))}
            </div>

            <!-- Expandir detalle -->
            <button
              class="servicio-toggle flex items-center gap-1.5 text-sm font-semibold transition-colors duration-300 mt-auto pt-2 border-t border-gray-100"
              class:list={[s.color === 'accent' ? 'text-accent hover:text-accent-hover' : 'text-primary hover:text-primary-hover']}
              aria-expanded="false"
              data-target={s.id}
            >
              <span class="toggle-text">Ver más detalle</span>
              <ChevronDown size={16} stroke-width={2} class="toggle-icon transition-transform duration-300" />
            </button>

            <!-- Detalle colapsable -->
            <div
              class="servicio-detalle overflow-hidden max-h-0 transition-[max-height] duration-500 ease-in-out"
              id={`detalle-${s.id}`}
            >
              <p class="text-sm text-gray-600 leading-relaxed pt-4">
                {s.detalle}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.servicio-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const detalle = document.getElementById(`detalle-${targetId}`);
      if (!detalle) return;

      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        detalle.style.maxHeight = '0';
        btn.setAttribute('aria-expanded', 'false');
        btn.querySelector('.toggle-text')!.textContent = 'Ver más detalle';
        btn.querySelector('.toggle-icon')!.classList.remove('rotate-180');
      } else {
        detalle.style.maxHeight = `${detalle.scrollHeight}px`;
        btn.setAttribute('aria-expanded', 'true');
        btn.querySelector('.toggle-text')!.textContent = 'Ver menos';
        btn.querySelector('.toggle-icon')!.classList.add('rotate-180');
      }
    });
  });
</script>
