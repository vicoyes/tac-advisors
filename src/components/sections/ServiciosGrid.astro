    imgAlt: 'Dashboard con gráficos financieros y métricas de rendimiento',
    descripcion: 'Elaboramos y analizamos estados financieros para que la información no se quede en un documento técnico, sino que se convierta en una herramienta útil para entender la situación del negocio y actuar con criterio.',
    puntos: [
      'Elaboración de estados financieros',
      'Interpretación de resultados',
      'Identificación de tendencias y alertas',
      'Soporte para decisiones gerenciales',
    ],
  },
  {
    id: 'niif-pymes',
    icon: BookMarked,
    color: 'accent',
    titulo: 'NIIF para PyMEs 2027',
    subtitulo: 'Implementación NIIF para PyMEs',
    imagen: 'https://images.unsplash.com/photo-1507679799987-c73779587ccf?w=480&h=260&fit=crop&q=80',
    imgAlt: 'Profesional ejecutivo revisando documentación normativa',
    descripcion: 'Acompañamos la adopción y aplicación de estándares NIIF para PyMEs, asegurando que su empresa avance con orden, cumplimiento y claridad en la transición normativa.',
    puntos: [
      'Diagnóstico de situación actual',
      'Ajustes contables y criterios técnicos',
      'Acompañamiento en implementación',
      'Orientación para cumplimiento futuro',
    ],
  },
  {
    id: 'revisoria-fiscal',
    icon: ShieldCheck,
    color: 'primary',
    titulo: 'Revisoría Fiscal',
    subtitulo: 'Supervisión y control con criterio técnico',
    imagen: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=480&h=260&fit=crop&q=80',
    imgAlt: 'Auditor revisando informes financieros',
    descripcion: 'Prestamos el servicio de revisoría fiscal con independencia, rigurosidad y enfoque preventivo, contribuyendo a fortalecer el control, la transparencia y la confianza en la gestión empresarial.',
    puntos: [
      'Revisión y control independiente',
      'Seguimiento a cumplimiento normativo',
      'Observación de riesgos y hallazgos',
      'Recomendaciones para fortalecer procesos',
    ],
  },
  {
    id: 'analisis-financiero',
    icon: BarChart3,
    color: 'accent',
    titulo: 'Análisis Financiero Estratégico',
    subtitulo: 'Análisis financiero para decisiones estratégicas',
    imagen: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=480&h=260&fit=crop&q=80',
    imgAlt: 'Pantalla con gráficos analíticos y visualización de datos',
    descripcion: 'Estudiamos la información financiera de su empresa para identificar patrones, riesgos, oportunidades y áreas de mejora. Utilizamos herramientas de análisis e inteligencia artificial como apoyo para ofrecer una lectura más útil.',
    puntos: [
      'Evaluación de rentabilidad y desempeño',
