      'Revisión tributaria periódica',
      'Planeación fiscal',
      'Presentación y control de obligaciones',
      'Acompañamiento ante requerimientos',
    ],
  },
  {
    id: 'gestion-nomina',
    icon: Users,
    color: 'primary',
    titulo: 'Gestión de Nómina y Prestaciones',
    subtitulo: 'Gestión laboral confiable',
    imagen: 'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=480&h=260&fit=crop&q=80',
    imgAlt: 'Equipo de trabajo colaborando en oficina corporativa',
    descripcion: 'Administramos procesos de nómina y prestaciones con precisión y cumplimiento, ayudando a reducir errores, ordenar la operación laboral y brindar tranquilidad administrativa.',
    puntos: [
      'Liquidación de nómina',
      'Prestaciones sociales',
      'Seguridad social y aportes',
      'Soporte en procesos laborales recurrentes',
    ],
  },
  {
    id: 'facturacion-electronica',
    icon: Zap,
    color: 'accent',
    titulo: 'Facturación Electrónica DIAN',
    subtitulo: 'Cumplimiento electrónico ante la DIAN',
    imagen: 'https://images.unsplash.com/photo-1563986768494-4dee2763ff3f?w=480&h=260&fit=crop&q=80',
    imgAlt: 'Pantalla digital mostrando sistema de facturación electrónica',
    descripcion: 'Le ayudamos a implementar y mantener procesos de facturación electrónica alineados con la normativa vigente, reduciendo fricciones operativas y mejorando el control documental.',
    puntos: [
      'Implementación y acompañamiento',
      'Validación de cumplimiento',
      'Revisión de procesos relacionados',
      'Soporte en operación documental',
    ],
  },
  {
    id: 'estados-financieros',
    icon: PieChart,
    color: 'primary',
    titulo: 'Estados Financieros e Interpretación',
