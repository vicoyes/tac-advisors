---
import {
  Calculator,
  Scale,
  Users,
  Zap,
  PieChart,
  BookMarked,
  ShieldCheck,
  BarChart3,
  Landmark,
  Monitor,
  ClipboardCheck,
  ChevronDown,
  CheckCircle2,
  ArrowRight,
} from 'lucide-astro';
import { withBase } from '../../utils/paths';

const servicios = [
  {
    id: 'outsourcing-contable',
    icon: Calculator,
    color: 'primary',
    titulo: 'Outsourcing Contable',
    subtitulo: 'Gestión contable integral',
