      'Orientación en estructura inicial',
      'Acompañamiento documental',
      'Definición de aspectos básicos de operación',
      'Soporte en primeras obligaciones',
    ],
  },
  {
    id: 'optimizacion-procesos',
    icon: Monitor,
    color: 'accent',
    titulo: 'Optimización y Modernización de Procesos Contables',
    subtitulo: 'Procesos más ordenados y eficientes',
    imagen: 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=480&h=260&fit=crop&q=80',
    imgAlt: 'Tecnología y automatización de procesos contables',
    descripcion: 'Revisamos y mejoramos procesos contables y administrativos para reducir tareas manuales, ordenar flujos de trabajo y aprovechar mejor la información disponible.',
    puntos: [
      'Diagnóstico de procesos actuales',
      'Identificación de ineficiencias',
      'Recomendaciones de mejora',
      'Integración de herramientas de apoyo',
    ],
  },
  {
    id: 'auditoria-aseguramiento',
    icon: ClipboardCheck,
    color: 'primary',
    titulo: 'Auditoría y Aseguramiento',
    subtitulo: 'Auditoría con enfoque en confianza y mejora',
    imagen: 'https://images.unsplash.com/photo-1434626881859-194d67b2b86f?w=480&h=260&fit=crop&q=80',
    imgAlt: 'Revisión de documentos financieros con verificación de calidad',
    descripcion: 'Realizamos procesos de auditoría y aseguramiento que fortalecen la confiabilidad de la información, ayudan a detectar oportunidades de mejora y aportan tranquilidad frente al control interno.',
    puntos: [
      'Revisión de información financiera',
      'Evaluación de controles',
      'Identificación de hallazgos',
      'Recomendaciones orientadas a mejora',
    ],
  },
];
---

<section class="py-20 bg-white" id="servicios">
  <div class="max-w-7xl mx-auto px-6">
    <div
      class="text-center max-w-3xl mx-auto mb-16 animate-fade-in opacity-0"
      data-animate
    >
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-4">
        Portafolio
      </div>
      <h2 class="font-display text-3xl lg:text-5xl font-bold text-gray-900 leading-tight mb-4">
        Nuestras <span class="text-primary">soluciones</span>
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed">
        Un portafolio diseñado para fortalecer la gestión contable, tributaria,
        laboral y financiera de su empresa.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {servicios.map((s, i) => (
        <div
          class="group servicio-card bg-gray-50 border border-gray-200 rounded-xl overflow-hidden
                 transition-all duration-300 hover:border-primary/40 hover:shadow-[0_8px_24px_rgba(0,71,171,0.1)]
                 animate-fade-in opacity-0 flex flex-col"
          style={`animation-delay: ${(i % 6) * 80}ms;`}
          data-animate
          data-servicio={s.id}
        >
          <div class="relative h-40 overflow-hidden">
            <img
              src={s.imagen}
              alt={s.imgAlt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              width="480"
              height="260"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-50 via-gray-50/20 to-transparent" aria-hidden="true" />
            <div class:list={[
              'absolute top-3 left-3 w-10 h-10 rounded-lg flex items-center justify-center backdrop-blur-sm shadow-md',
              s.color === 'accent' ? 'bg-accent/90 text-white' : 'bg-primary/90 text-white'
            ]}>
              <s.icon size={20} stroke-width={1.5} />
            </div>
          </div>

          <div class="p-6 pt-3 flex flex-col flex-1">
            <div class="mb-3">
              <h3 class="text-lg font-bold text-gray-900 leading-snug">{s.titulo}</h3>
              <p class:list={[
                'text-xs font-semibold uppercase tracking-wider mt-0.5',
                s.color === 'accent' ? 'text-accent' : 'text-primary'
              ]}>{s.subtitulo}</p>
            </div>

            <p class="text-sm text-gray-600 leading-relaxed mb-4 flex-1">
              {s.descripcion}
            </p>

            <div class="space-y-2 mb-4">
              {s.puntos.map((p) => (
                <div class="flex items-start gap-2">
                  <CheckCircle2
                    size={16}
                    stroke-width={2}
                    class:list={[
                      'shrink-0 mt-0.5',
                      s.color === 'accent' ? 'text-accent' : 'text-primary'
                    ]}
                  />
                  <span class="text-sm text-gray-600">{p}</span>
                </div>
              ))}
            </div>

            <a
              href={withBase(`servicios/${s.id}/`)}
              class:list={[
                'mt-auto inline-flex items-center gap-2 text-sm font-semibold transition-colors duration-300 no-underline',
                s.color === 'accent' ? 'text-accent hover:text-accent-hover' : 'text-primary hover:text-primary-hover'
              ]}
            >
              Ver detalle del servicio
              <ArrowRight size={16} stroke-width={2} />
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
