---
import { TrendingUp, Users, Shield, Award } from 'lucide-astro';

const metrics = [
  { icon: TrendingUp, value: '+$2.4B', label: 'En activos gestionados', color: 'text-accent' },
  { icon: Users, value: '120+', label: 'Empresas acompañadas', color: 'text-white' },
  { icon: Shield, value: '99.7%', label: 'Precisión en reportes', color: 'text-accent' },
  { icon: Award, value: '15+', label: 'Años de experiencia', color: 'text-white' },
];
---
<section class="relative py-20 overflow-hidden">
  <img
    src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1400&h=500&fit=crop&q=80"
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    aria-hidden="true"
  />
  <div class="absolute inset-0 bg-gray-900/85" aria-hidden="true" />
  <div class="absolute inset-0 bg-gradient-to-r from-primary/20 to-accent/10" aria-hidden="true" />

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="text-center mb-12 animate-fade-in opacity-0" data-animate>
      <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-3">
        Resultados
      </p>
      <h2 class="font-display text-3xl lg:text-4xl font-bold text-white">
        Resultados que respaldan nuestra metodología
      </h2>
      <p class="text-base text-gray-400 mt-3 max-w-2xl mx-auto">
        Más que entregar reportes, trabajamos para que la información financiera sirva como base
        real para mejorar el control, reducir fricciones y tomar decisiones con mayor criterio.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      {metrics.map(({ icon: Icon, value, label, color }, i) => (
        <div
          class="text-center animate-fade-in opacity-0"
          style={`animation-delay: ${i * 100 + 100}ms`}
          data-animate
        >
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-white/10 backdrop-blur-sm mb-4">
            <Icon size={28} stroke-width={1.5} class="text-accent" />
          </div>
          <p class:list={['text-4xl lg:text-5xl font-extrabold font-mono mb-2', color]}>
            {value}
          </p>
          <p class="text-sm text-gray-300">{label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
