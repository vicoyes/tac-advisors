---
import { TrendingUp, DollarSign, BarChart3, Users, ArrowRight } from 'lucide-astro';
import { withBase } from '../../utils/paths';

const beneficios = [
  { icon: TrendingUp, texto: 'Evaluación financiera para nuevos pasos del negocio' },
  { icon: DollarSign, texto: 'Mejor lectura de costos, márgenes y rentabilidad' },
  { icon: BarChart3, texto: 'Análisis útil para expansión, inversión y reorganización' },
  { icon: Users, texto: 'Acompañamiento estratégico en decisiones clave' },
];

const contactoHref = withBase('contacto/');
---
<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative animate-slide-in-left opacity-0" data-animate>
        <img
          src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=640&h=480&fit=crop&q=80"
          alt="Dashboard con métricas de crecimiento empresarial"
          class="rounded-2xl object-cover w-full h-[420px] shadow-xl"
          loading="lazy"
          width="640"
          height="480"
        />
        <div class="absolute -bottom-5 -right-5 bg-white border-2 border-primary rounded-xl p-4 shadow-lg">
          <p class="text-xs text-gray-500 font-mono uppercase tracking-wider">Enfoque</p>
          <p class="text-lg font-bold text-primary font-mono">Crecimiento sólido</p>
        </div>
      </div>

      <div class="animate-fade-in opacity-0" data-animate>
        <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-4">
          Decisiones de Crecimiento
        </div>

        <h2 class="font-display text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-4">
          Decisiones de crecimiento respaldadas por
          <span class="text-primary">información</span>
        </h2>

        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          Crecer sin información clara puede generar costos innecesarios y decisiones poco rentables.
          Nuestro acompañamiento permite analizar escenarios, comprender mejor la rentabilidad y tomar
          decisiones empresariales con mayor criterio.
        </p>

        <div class="space-y-3 mb-8">
          {beneficios.map((b) => (
            <div class="flex items-center gap-3 bg-white border border-gray-100 rounded-lg px-4 py-3
                        transition-all duration-300 hover:border-primary/30 hover:shadow-sm">
              <b.icon size={20} stroke-width={1.5} class="text-primary shrink-0" />
              <span class="text-base text-gray-700 font-medium">{b.texto}</span>
            </div>
          ))}
        </div>

        <a
          href={contactoHref}
          data-booking
          class="inline-flex items-center gap-2 text-primary font-semibold text-base transition-all duration-300 hover:gap-3"
        >
          Solicitar diagnóstico empresarial
          <ArrowRight size={18} stroke-width={2} />
        </a>
      </div>
    </div>
  </div>
</section>
