---
import { Scale, Search, ShieldAlert, FileText, ArrowRight } from 'lucide-astro';
import { withBase } from '../../utils/paths';

const beneficios = [
  { icon: Search, texto: 'Revisión estratégica de obligaciones fiscales' },
  { icon: Scale, texto: 'Planeación tributaria alineada con la operación' },
  { icon: ShieldAlert, texto: 'Disminución de riesgos por errores u omisiones' },
  { icon: FileText, texto: 'Acompañamiento frente a cambios normativos' },
];

const contactoHref = withBase('contacto/');
---
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="animate-fade-in opacity-0 order-2 lg:order-1" data-animate>
        <div class="inline-flex items-center gap-2 bg-accent/10 text-accent px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-4">
          Planeación Tributaria
        </div>

        <h2 class="font-display text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-4">
          Planeación tributaria con
          <span class="text-accent">enfoque preventivo</span>
        </h2>

        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          Una gestión tributaria sólida no consiste solo en responder a las obligaciones, sino en
          anticiparse a ellas. Trabajamos con un enfoque preventivo que ayuda a reducir contingencias,
          optimizar la carga fiscal dentro del marco normativo y brindar mayor tranquilidad a la empresa.
        </p>

        <div class="space-y-3 mb-8">
          {beneficios.map((b) => (
            <div class="flex items-center gap-3 bg-gray-50 border border-gray-100 rounded-lg px-4 py-3
                        transition-all duration-300 hover:border-accent/30 hover:shadow-sm">
              <b.icon size={20} stroke-width={1.5} class="text-accent shrink-0" />
              <span class="text-base text-gray-700 font-medium">{b.texto}</span>
            </div>
          ))}
        </div>

        <a
          href={contactoHref}
          data-booking
          class="inline-flex items-center gap-2 text-accent font-semibold text-base transition-all duration-300 hover:gap-3"
        >
          Solicitar diagnóstico fiscal
          <ArrowRight size={18} stroke-width={2} />
        </a>
      </div>

      <div class="relative animate-slide-in-right opacity-0 order-1 lg:order-2" data-animate>
        <img
          src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=640&h=480&fit=crop&q=80"
          alt="Documentos de planeación tributaria y fiscal"
          class="rounded-2xl object-cover w-full h-[420px] shadow-xl"
          loading="lazy"
          width="640"
          height="480"
        />
        <div class="absolute -bottom-5 -left-5 bg-white border-2 border-accent rounded-xl p-4 shadow-lg">
          <p class="text-xs text-gray-500 font-mono uppercase tracking-wider">Enfoque</p>
          <p class="text-lg font-bold text-accent font-mono">Prevención fiscal</p>
        </div>
      </div>
    </div>
  </div>
</section>
