import SolucionesHero from '../components/sections/SolucionesHero.astro';
import SolucionesIntro from '../components/sections/SolucionesIntro.astro';
import VerticalFinancial from '../components/sections/VerticalFinancial.astro';
import VerticalTax from '../components/sections/VerticalTax.astro';
import VerticalGrowth from '../components/sections/VerticalGrowth.astro';
import ServiciosGrid from '../components/sections/ServiciosGrid.astro';
import SolucionesDiferencial from '../components/sections/SolucionesDiferencial.astro';
import SolucionesTecnologia from '../components/sections/SolucionesTecnologia.astro';
import SolucionesParaQuien from '../components/sections/SolucionesParaQuien.astro';
import SolucionesCTA from '../components/sections/SolucionesCTA.astro';
